# ============================================
# Environment Variables Template
# Copy this file to the appropriate locations
# and fill in your actual values.
# ============================================

# ── Backend (copy to backend/.env) ──────────

# Database
DATABASE_URL=mysql://user:password@localhost:3306/your_database_name

# JWT Authentication
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-to-another-random-string
JWT_REFRESH_EXPIRATION=7d

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# ── Frontend (copy to frontend/.env.production) ──

VITE_API_URL=https://your-domain.com
